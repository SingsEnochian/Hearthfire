# starwell-server environment configuration
# Copy this to .env and fill in your values.
# server.mjs and arkfire-dispatch.mjs read these at startup.

# ── Server ────────────────────────────────────────────────────────────────
PORT=4173
HOST=0.0.0.0

# ── Ollama ports — one instance per model for true parallel chorus ────────
# Start each with: $env:OLLAMA_HOST="127.0.0.1:PORT"; ollama serve
# All instances share the same model cache at %USERPROFILE%\.ollama\models

OLLAMA_URL_QWYTHOS=http://127.0.0.1:11434
OLLAMA_URL_YGG=http://127.0.0.1:11435
OLLAMA_URL_GLM4=http://127.0.0.1:11436
OLLAMA_URL_R1=http://127.0.0.1:11437
OLLAMA_URL_GENERAL=http://127.0.0.1:11434

# Per-model overrides (uncomment and set when the recommended model is pulled)
# OLLAMA_URL_AGENTS_A1=http://127.0.0.1:11438
# OLLAMA_URL_QWEN3_CODER=http://127.0.0.1:11439
# OLLAMA_URL_DEEPSEEK_FLASH=http://127.0.0.1:11437

# ── Cloud API keys (server-side only — never sent to client) ──────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# DEEPSEEK_API_KEY=

# Cloud failsafe models (fast, low-cost — used only when local Ollama is down)
OPENAI_FAILSAFE_MODEL=gpt-4o-mini
ANTHROPIC_FAILSAFE_MODEL=claude-haiku-4-5-20251001

# ── Supabase (Flameclyffe project rufrmjyusalnifpegllj) ───────────────────
# Publishable key: safe for server-side reads (anon-tier, RLS applies).
# Secret key: full access — keep out of client code and git.
SUPABASE_URL=https://rufrmjyusalnifpegllj.supabase.co
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# ── Vee's recommended models — activate when pulled ───────────────────────
# MODEL_AGENTS_A1=agents-a1:latest
# OLLAMA_URL_AGENTS_A1=http://127.0.0.1:11438

# MODEL_QWEN3_CODER=qwen3-coder:latest
# OLLAMA_URL_QWEN3_CODER=http://127.0.0.1:11439

# MODEL_DEEPSEEK_V4=deepseek-v4:latest
